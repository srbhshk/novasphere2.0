# =============================================================================
# 6. DOCKER & DEPLOYMENT
# =============================================================================

docker:
  philosophy: >
    One command: docker compose up.
    Model pulls on first start, cached in volume on subsequent starts.
    No Ollama installation required. No env setup. No instructions to follow.

  web_service:
    build: ./docker/Dockerfile
    next_output: standalone (required — set in next.config.ts)
    env:
      DATABASE_URL: "file:./data/app.db"
      OLLAMA_BASE_URL: "http://ollama:11434"
      OLLAMA_MODEL: "qwen2.5:0.5b"
      BETTER_AUTH_SECRET: "change-me-32-chars"
      NEXT_PUBLIC_APP_URL: "http://localhost:3000"
    volumes: [db_data:/app/data]
    depends_on: ollama (health check)

  ollama_service:
    image: ollama/ollama:latest
    volumes: [ollama_models:/root/.ollama]
    startup: >
      ollama serve in background, sleep 5, ollama pull qwen2.5:0.5b, wait
    healthcheck: "curl -f http://localhost:11434/api/tags"
    start_period: 30s (model pull on first run)

  dockerfile:
    stages: [deps, builder, runner]
    base: node:20-alpine
    runner: non-root user, standalone Next.js output only
    cmd: node apps/web/server.js

  dev_workflow: >
    ollama serve (separate terminal)
    pnpm dev (from apps/web or root)
    OLLAMA_BASE_URL=http://localhost:11434 in .env.local

# =============================================================================
# 7. ENVIRONMENT VARIABLES
# =============================================================================

env:
  validation: apps/web/src/lib/env.ts — Zod, fail fast on missing required vars

  variables: |
    # App
    NEXT_PUBLIC_APP_URL          # http://localhost:3000
    NEXT_PUBLIC_DATA_SOURCE      # mock | api  (default: mock)

    # Database
    DATABASE_URL                 # file:./dev.db | libsql://... | postgres://...

    # Auth
    BETTER_AUTH_SECRET           # REQUIRED — 32+ char random string
    BETTER_AUTH_URL              # = NEXT_PUBLIC_APP_URL

    # OAuth (optional)
    GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET
    GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET

    # AI — Ollama (local, default)
    OLLAMA_BASE_URL              # http://localhost:11434 or http://ollama:11434
    OLLAMA_MODEL                 # qwen2.5:0.5b

    # AI — External (server-side only, optional)
    ANTHROPIC_API_KEY            # activates Claude via AI SDK
    OPENAI_API_KEY               # activates OpenAI via AI SDK

    # Security
    RATE_LIMIT_AGENT_RPM         # default: 20

# =============================================================================
# 8. NAMING CONVENTIONS
# =============================================================================

naming:
  files:
    components:  "PascalCase.tsx"
    css_modules: "PascalCase.module.css"
    tests:       "PascalCase.test.tsx"
    hooks:       "camelCase — useResourceAction.ts"
    stores:      "camelCase — domain.store.ts"
    types:       "camelCase — domain.types.ts"
    schemas:     "camelCase — resource.schema.ts"
    adapters:    "camelCase — provider.adapter.ts"
    barrel:      "index.ts always"

  typescript:
    components:  PascalCase
    props:       "[ComponentName]Props"
    hooks:       "use[Resource][Action]"
    stores:      "use[Domain]Store"
    constants:   SCREAMING_SNAKE_CASE
    zod_schemas: "[resource]Schema"

  css:
    module_classes: camelCase
    variables:      "--ns-[category]-[property]"

  git:
    branches: "[type]/[scope]/[description]"
    commits:  "Conventional Commits v1.0.0"
    scopes:   [tokens, db, agent-core, tenant-core, ui-glass, ui-bento,
               ui-charts, ui-auth, ui-agent, ui-shell, web, docker, genui]

# =============================================================================
# 9. PACKAGE.JSON TEMPLATE
# =============================================================================

package_json_template: |
  {
    "name": "@novasphere/[package-name]",
    "version": "0.0.1",
    "license": "UNLICENSED",
    "main":   "./dist/index.cjs",
    "module": "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports": {
      ".": {
        "types":   "./dist/index.d.ts",
        "import":  "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "files": ["dist"],
    "scripts": {
      "build":     "tsup",
      "dev":       "tsup --watch",
      "typecheck": "tsc --noEmit",
      "lint":      "eslint src --max-warnings 0",
      "test":      "vitest run",
      "test:watch":"vitest"
    },
    "peerDependencies": {},
    "dependencies": {},
    "devDependencies": {}
  }

rules:
  - "types" in exports MUST be first
  - license is UNLICENSED until explicitly changed
  - peerDependencies: react, react-dom, framework libs (NOT bundled)
  - dependencies: @novasphere/* workspace deps only
  - devDependencies: tsup, typescript, vitest, RTL, @testing-library/jest-dom

# =============================================================================
# 10. CURSOR BEHAVIOUR
# =============================================================================

cursor_behaviour:
  before_writing:
    - Identify package using Section 3 registry
    - Confirm file location matches Section 5 structure
    - Check boundary rules — is this import allowed?
    - If library not in Section 4 — STOP and ask
    - If new package needed — STOP and ask
    - If ambiguous — STOP and ask. Never guess.

  while_writing:
    - Never placeholder content in production paths
    - Never console.log
    - Never skip TypeScript types
    - Never hardcode a design value — add to tokens first
    - Never inline a prompt — add to agent-core/src/prompts.ts
    - Never alias third-party modules in vitest.config.ts
    - Never stub @hookform/resolvers/zod in tests
    - Write test in same session as component
    - Install the real dependency — never mock it

  never_do:
    - Never use Pages Router
    - Never use `any`
    - Never use streamUI from ai/rsc
    - Never import ai or @ai-sdk/* inside any package
    - Never import better-auth inside any package
    - Never import nova.config.ts inside any package
    - Never hardcode OLLAMA_BASE_URL — always from env
    - Never modify files in src/ui/ (shadcn source)
    - Never push directly to main
    - Never commit secrets or .env.local

