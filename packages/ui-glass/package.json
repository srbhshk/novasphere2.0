    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "esbuild-css-modules-plugin": "^3.1.5",
    "jsdom": "latest",
    "postcss": "^8.5.8",
    "postcss-modules": "^6.0.1",
    "tsup": "latest",
    "typescript": "^5.4.0",
    "vitest": "latest"
  }
